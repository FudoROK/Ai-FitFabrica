# Post-billing staging override template.
# Copy to .env.post-billing-staging.local after billing/auth/provider access is restored.
# This file is intentionally production-like: it must pass production_infrastructure_readiness_gate.py --require-production.

APP_ENV_FILE=.env.post-billing-staging.local
ENVIRONMENT=staging
APP_HOST=0.0.0.0
APP_PORT=8080

MESSAGING_PROVIDER=none
PROJECT_ID=ai-fitfabrica
EVENT_TOPIC_NAME=staging-agent-jobs

PUBLIC_STATUS_ENDPOINTS_ENABLED=true
STATUS_ENDPOINT_TOKEN=replace-with-real-staging-status-token

AUTH_PROVIDER=firebase
AUTH_SESSION_COOKIE_NAME=fitfabrica_session
ADMIN_API_TOKEN=replace-with-real-internal-admin-token
ALLOW_UNSAFE_ADMIN_HEADER_AUTH=false
ENABLE_ADMIN_TAXONOMY=true
ENABLE_ADMIN_BUSINESS_CATALOG=true
ENABLE_ADMIN_COSTS=true

BILLING_CORE_ENABLED=true
DEFAULT_PERSON_CREDIT_ACCOUNT_ID=public-person
DEFAULT_BUSINESS_CREDIT_ACCOUNT_ID=public-business
TRY_ON_BASE_CREDIT_COST=12
PRODUCT_CARD_BASE_CREDIT_COST=18
CONTENT_PACKAGE_BASE_CREDIT_COST=14
PRICING_BASE_CREDIT_COST=6

POSTGRES_DSN=postgresql+asyncpg://fitfabrica:replace-with-real-password@postgres:5432/fitfabrica
PORTABLE_POSTGRES_DB=fitfabrica
PORTABLE_POSTGRES_USER=fitfabrica
PORTABLE_POSTGRES_PASSWORD=replace-with-real-password
REDIS_URL=redis://redis:6379/0

OBJECT_STORAGE_BACKEND=s3
OBJECT_STORAGE_BUCKET_NAME=fitfabrica-staging
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-real-minio-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-real-minio-secret-key
MINIO_ROOT_USER=replace-with-real-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-real-minio-secret-key
OBJECT_STORAGE_PREFIX=fitfabrica

VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PREFIX=fitfabrica

RATE_LIMIT_BACKEND=redis
RATE_LIMIT_MAX_EVENTS=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_MODE=closed
RATE_LIMIT_COLLECTION=runtime_rate_limits

OPERATIONS_QUEUE_BACKEND=redis
OPERATIONS_QUEUE_NAME=fitfabrica:workflow-queue
OPERATIONS_WORKER_NAME=portable-worker
OPERATIONS_WORKER_POLL_INTERVAL_SECONDS=1.0

LLM_PROVIDER=vertex
LLM_GATEWAY_MODE=live
IMAGE_EDITING_PROVIDER=google_genai
VERTEX_PROJECT=ai-fitfabrica
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
VERTEX_AGENT_RESOURCE=projects/ai-fitfabrica/locations/us-central1/reasoningEngines/replace-with-primary-agent-id
VERTEX_VIRTUAL_TRY_ON_LOCATION=global
VERTEX_VIRTUAL_TRY_ON_MODEL=virtual-try-on-001

TRY_ON_GENERATION_BACKEND=vertex_virtual_try_on
ENABLE_REAL_TRY_ON_GENERATION=true
TRY_ON_VERTEX_FAILURE_FALLBACK_BACKEND=none
ALLOW_UNSAFE_TRY_ON_VERTEX_FALLBACK_IN_PRODUCTION=false
TRY_ON_QUALITY_VERIFIER_BACKEND=model_backed
TRY_ON_REPAIR_BACKEND=provider_runtime
TRY_ON_STYLIST_BACKEND=model_backed

ENABLE_SEARCH_ENGINE_DISCOVERY=false
SEARCH_ENGINE_DISCOVERY_PROVIDER=disabled
SEARCH_ENGINE_DISCOVERY_DAILY_LIMIT=0
# SEARCH_ENGINE_DISCOVERY_API_KEY=replace-with-approved-search-api-key
