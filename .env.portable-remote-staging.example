# Portable remote staging contour for Ai Fitfabrica
# Use this on a Linux VM/VPS where Docker Engine is available.

APP_ENV_FILE=.env.portable-remote-staging.local
ENVIRONMENT=staging
APP_HOST=0.0.0.0
APP_PORT=8080
CADDY_SITE_ADDRESS=api-staging.fitfabrica.ai

MESSAGING_PROVIDER=none
PROJECT_ID=ai-fitfabrica
EVENT_TOPIC_NAME=staging-agent-jobs
LLM_PROVIDER=fake
MEMORY_SUMMARY_ENABLED=false
MEMORY_SUMMARY_TASK_AUTH_AUDIENCE=https://tasks.staging.example/memory-summary
MEMORY_SUMMARY_TASK_ALLOWED_SERVICE_ACCOUNTS=staging-task@ai-fitfabrica.iam.gserviceaccount.com

PUBLIC_STATUS_ENDPOINTS_ENABLED=true
STATUS_ENDPOINT_TOKEN=replace-with-staging-status-token
CORS_ALLOWED_ORIGINS=https://staging.fitfabrica.ai

POSTGRES_DSN=postgresql+asyncpg://fitfabrica:replace-with-password@postgres:5432/fitfabrica
PORTABLE_POSTGRES_DB=fitfabrica
PORTABLE_POSTGRES_USER=fitfabrica
PORTABLE_POSTGRES_PASSWORD=replace-with-password
REDIS_URL=redis://redis:6379/0
OBJECT_STORAGE_BACKEND=s3
OBJECT_STORAGE_BUCKET_NAME=fitfabrica-staging
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-minio-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-minio-secret-key
MINIO_ROOT_USER=replace-with-minio-access-key
MINIO_ROOT_PASSWORD=replace-with-minio-secret-key
OBJECT_STORAGE_PREFIX=fitfabrica

VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_PREFIX=fitfabrica

RATE_LIMIT_BACKEND=redis
RATE_LIMIT_MAX_EVENTS=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_MODE=closed
RATE_LIMIT_COLLECTION=runtime_rate_limits

OPERATIONS_QUEUE_BACKEND=redis
OPERATIONS_QUEUE_NAME=fitfabrica:workflow-queue
OPERATIONS_WORKER_NAME=portable-worker
OPERATIONS_WORKER_POLL_INTERVAL_SECONDS=1.0

TRY_ON_GENERATION_BACKEND=sandbox_fake
ENABLE_REAL_TRY_ON_GENERATION=false
TRY_ON_VERTEX_FAILURE_FALLBACK_BACKEND=none
TRY_ON_QUALITY_VERIFIER_BACKEND=model_backed
TRY_ON_REPAIR_BACKEND=provider_runtime
TRY_ON_STYLIST_BACKEND=model_backed
