# --- MESSAGING ---
# Web-first FitFabrica deployments do not use a messaging ingress runtime.
MESSAGING_PROVIDER=none

# --- CORE RUNTIME IDENTIFIERS ---
# Use PROJECT_ID as the portable contract. GCP_PROJECT_ID remains a compatibility alias.
PROJECT_ID=your-runtime-project-id

# --- PROVIDER / EVENT RUNTIME ---
# EVENT_TOPIC_NAME is the portable alias for the current event topic contract.
EVENT_TOPIC_NAME=ai-assistant-events
VERTEX_PROJECT=your-vertex-project-id
VERTEX_LOCATION=us-central1
VERTEX_VIRTUAL_TRY_ON_LOCATION=global
VERTEX_VIRTUAL_TRY_ON_MODEL=virtual-try-on-001
VERTEX_MODEL=gemini-2.5-flash
VERTEX_AGENT_RESOURCE=projects/your-vertex-project-id/locations/your-vertex-location/reasoningEngines/your-primary-agent-id
VERTEX_MEMORY_DAILY_AGENT_RESOURCE=projects/your-vertex-project-id/locations/your-vertex-location/reasoningEngines/your-daily-memory-agent-id
VERTEX_MEMORY_ROLLING_AGENT_RESOURCE=projects/your-vertex-project-id/locations/your-vertex-location/reasoningEngines/your-rolling-memory-agent-id

# --- PROVIDER-SPECIFIC EVENT ADAPTERS ---
PUBSUB_SUBSCRIPTION_ID=ai-assistant-webhook-sub
PUBSUB_PUSH_SERVICE_ACCOUNT_EMAIL=pubsub-service-account@your-gcp-project-id.iam.gserviceaccount.com
PUBSUB_PUSH_AUDIENCE=

# --- HUBSPOT (Optional) ---
# HUBSPOT_PRIVATE_APP_TOKEN=your-hubspot-private-app-token

# --- APP ---
APP_HOST=0.0.0.0
APP_PORT=8080
MEMORY_SUMMARY_TASK_AUTH_AUDIENCE=your-memory-summary-task-audience
MEMORY_SUMMARY_TASK_ALLOWED_SERVICE_ACCOUNTS=your-service-account@your-gcp-project-id.iam.gserviceaccount.com
MEMORY_SUMMARY_BATCH_LIMIT=100
MEMORY_ROLLING_POINTER_READ_ENABLED=true
PUBLIC_STATUS_ENDPOINTS_ENABLED=false
STATUS_ENDPOINT_TOKEN=your-health-check-api-key
ADMIN_API_TOKEN=your-internal-admin-api-token
ALLOW_UNSAFE_ADMIN_HEADER_AUTH=false
ENABLE_ADMIN_TAXONOMY=false
ENABLE_ADMIN_BUSINESS_CATALOG=false
ENABLE_ADMIN_COSTS=false
ENABLE_SEARCH_ENGINE_DISCOVERY=false
SEARCH_ENGINE_DISCOVERY_PROVIDER=disabled
SEARCH_ENGINE_DISCOVERY_DAILY_LIMIT=0
# SEARCH_ENGINE_DISCOVERY_API_KEY=your-approved-search-api-key

# --- LLM ---
LLM_PROVIDER=vertex
LLM_GATEWAY_MODE=live

# --- RATE LIMIT ---
ENABLE_DISTRIBUTED_RATE_LIMIT=true
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_MAX_EVENTS=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_FAIL_MODE=closed
RATE_LIMIT_COLLECTION=runtime_rate_limits

# --- PORTABLE PLATFORM FOUNDATION ---
POSTGRES_DSN=postgresql+asyncpg://fitfabrica:fitfabrica@localhost:5432/fitfabrica
REDIS_URL=redis://localhost:6379/0
OBJECT_STORAGE_BUCKET_NAME=fitfabrica
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT_URL=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_PREFIX=fitfabrica
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=fitfabrica
OBJECT_STORAGE_BACKEND=s3
VECTOR_BACKEND=qdrant
BILLING_CORE_ENABLED=false
DEFAULT_PERSON_CREDIT_ACCOUNT_ID=public-person
DEFAULT_BUSINESS_CREDIT_ACCOUNT_ID=public-business
TRY_ON_BASE_CREDIT_COST=12
PRODUCT_CARD_BASE_CREDIT_COST=18
CONTENT_PACKAGE_BASE_CREDIT_COST=14
PRICING_BASE_CREDIT_COST=6
TRY_ON_GENERATION_BACKEND=sandbox_fake
# available: sandbox_fake | provider_runtime | vertex_virtual_try_on
ENABLE_REAL_TRY_ON_GENERATION=false
TRY_ON_VERTEX_FAILURE_FALLBACK_BACKEND=none
# available: none | provider_runtime | sandbox_fake
TRY_ON_QUALITY_VERIFIER_BACKEND=model_backed
# available: deterministic | model_backed
TRY_ON_REPAIR_BACKEND=provider_runtime
# available: deterministic | provider_runtime
TRY_ON_STYLIST_BACKEND=model_backed
# available: deterministic | model_backed
OPERATIONS_QUEUE_BACKEND=in_memory
OPERATIONS_QUEUE_NAME=fitfabrica:workflow-queue
OPERATIONS_WORKER_NAME=portable-worker
OPERATIONS_WORKER_POLL_INTERVAL_SECONDS=1.0
ALLOW_UNSAFE_TRY_ON_VERTEX_FALLBACK_IN_PRODUCTION=false
