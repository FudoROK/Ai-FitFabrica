# Real Vertex Try-On staging activation pack
# Fill only with approved staging resources. Do not reuse production values here.

ENVIRONMENT=staging
GCP_PROJECT_ID=ai-fitfabrica
PUBSUB_TOPIC_NAME=replace-with-approved-staging-pubsub-topic
LLM_PROVIDER=fake
MEMORY_SUMMARY_ENABLED=false

# Public status access for deployed readiness checks
PUBLIC_STATUS_ENDPOINTS_ENABLED=false
STATUS_ENDPOINT_TOKEN=replace-with-approved-staging-status-token

# Real Try-On activation
TRY_ON_GENERATION_BACKEND=vertex_virtual_try_on
ENABLE_REAL_TRY_ON_GENERATION=true
TRY_ON_VERTEX_FAILURE_FALLBACK_BACKEND=none
ALLOW_UNSAFE_TRY_ON_VERTEX_FALLBACK_IN_PRODUCTION=false

# Vertex Virtual Try-On
VERTEX_PROJECT=replace-with-approved-staging-vertex-project
VERTEX_VIRTUAL_TRY_ON_LOCATION=global
VERTEX_VIRTUAL_TRY_ON_MODEL=virtual-try-on-001

# Durable runtime dependencies
OBJECT_STORAGE_BACKEND=s3
OBJECT_STORAGE_BUCKET_NAME=replace-with-approved-staging-bucket
OBJECT_STORAGE_REGION=replace-with-approved-staging-region
OBJECT_STORAGE_ENDPOINT_URL=replace-with-approved-staging-endpoint-if-needed
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-approved-staging-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-approved-staging-secret-key
POSTGRES_DSN=replace-with-approved-staging-postgres-dsn
OPERATIONS_QUEUE_BACKEND=redis
REDIS_URL=replace-with-approved-staging-redis-url

# Recommended explicit worker identity
OPERATIONS_WORKER_NAME=staging-try-on-worker
